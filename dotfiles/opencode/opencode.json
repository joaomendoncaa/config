{
    "$schema": "https://opencode.ai/config.json",
    "share": "manual",
    "autoupdate": true,
    "default_agent": "build",
    "model": "opencode-go/deepseek-v4-flash-free",
    "references": {
        "config": {
            "path": "~/.config.jmmm.sh",
            "description": "Use for personal configuration files"
        },
        "voxtype": {
            "path": "~/lab/voxtype",
            "description": "Use for patching voxtype"
        },
        "hyprland": {
            "repository": "github.com/hyprwm/Hyprland",
            "branch": "main",
            "description": "Use for updating hyprland configurations"
        },
        "omarchy-4": {
            "repository": "github.com/basecamp/omarchy",
            "branch": "omarchy-shell",
            "description": "Use for omarchy's migration to quickshell and lua-based hyprland"
        },
        "herdr": {
            "repository": "https://github.com/ogulcancelik/herdr",
            "branch": "master",
            "description": "Use for any question regarding herdr"
        },
        "oil": {
            "repository": "https://github.com/stevearc/oil.nvim",
            "branch": "master",
            "description": "Use for any question regarding {oil,oil.nvim}"
        }
    }
}
