#!/usr/bin/env bash

export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && add_to_path "$PYENV_ROOT/bin"
add_to_path "$PYENV_ROOT/shims"
export PYENV_SHELL=bash

# pyenv rehash creates/updates shim scripts in ~/.pyenv/shims/. It only
# needs to run when Python versions or packages with console scripts are
# installed/removed — not on every shell startup. Background it so it
# never blocks the prompt. Shims from the last rehash remain functional.
{ command pyenv rehash 2>/dev/null; } & disown 2>/dev/null

pyenv() {
    local command=${1:-}
    [ "$#" -gt 0 ] && shift
    case "$command" in
    rehash|shell) eval "$(pyenv "sh-$command" "$@")" ;;
    *) command pyenv "$command" "$@" ;;
    esac
}
