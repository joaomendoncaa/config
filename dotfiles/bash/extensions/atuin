#!/usr/bin/env bash
# Atuin shell integration with zero startup/per-command overhead.
#
# What was here before: the 380-line bash-preexec library (installs a
# DEBUG trap that fires on EVERY simple command) + `eval "$(atuin init
# bash)"` (forks atuin to generate a 745-line init script on every shell
# startup). Together: ~13ms startup + ~0.85ms per command from the DEBUG
# trap dispatch.
#
# What's here now:
# - The `atuin init bash` output is cached to a file and sourced directly
#   (no fork to generate it). Regenerate by deleting the cache file.
# - No bash-preexec DEBUG trap. Commands are captured from `history 1`
#   (a builtin) in PROMPT_COMMAND — no per-simple-command trap overhead.
# - Recording is handed to a coproc worker via a pipe write (no per-command
#   fork). The coproc runs `atuin history start`/`end` at its own pace.
# - All atuin features preserved: Ctrl+R search, up-arrow, sync, exit codes.
#   Tradeoff: command duration is not recorded (~0), since there's no
#   preexec to capture the start time. Commands not in bash history (e.g.
#   space-prefixed with ignorespace) are not captured.

# --- Cache and source the atuin init script (keybindings, functions) ---
__atuin_cache_dir="$HOME/.cache/bash-init"
[[ -d "$__atuin_cache_dir" ]] || mkdir -p "$__atuin_cache_dir" 2>/dev/null
__atuin_cache="$__atuin_cache_dir/atuin.bash"

if [[ -s "$__atuin_cache" ]]; then
    source "$__atuin_cache"
else
    eval "$(atuin init bash)"
    atuin init bash > "$__atuin_cache" 2>/dev/null || rm -f "$__atuin_cache"
fi

# --- Coproc worker: receives commands via pipe, records to atuin DB ---
if [[ -z ${__atuin_worker+x} ]] && ((BASH_VERSINFO[0] >= 4)); then
    coproc __atuin_worker {
        line= EXIT= qcmd= cmd= id=
        while IFS= read -r line; do
            EXIT=${line%%$'\t'*}
            qcmd=${line#*$'\t'}
            eval "cmd=$qcmd"
            [[ -n $cmd ]] || continue
            id=$(atuin history start -- "$cmd" 2>/dev/null) || continue
            [[ -n $id ]] && atuin history end --exit "$EXIT" -- "$id" >/dev/null 2>&1
        done
    } 2>/dev/null
fi

# --- History-based command capture (replaces bash-preexec DEBUG trap) ---
# In PROMPT_COMMAND, `history 1` (builtin) returns the just-executed
# command. $? has its exit code. We compare against the last-seen command
# to detect new entries, then hand off to the coproc via a pipe write
# (no fork). $() around `history 1` is one subshell per prompt — cheaper
# than the DEBUG trap which fired on every simple command.
__atuin_precmd() {
    local EXIT=$?
    [[ -n "${__atuin_worker[1]:-}" ]] || return 0
    local last _histnum
    last=$(HISTTIMEFORMAT='' builtin history 1)
    # `history 1` outputs "  NNN  command" (or "  NNN* command"). Use
    # read to split the number into a throwaway var — fork-free (here-
    # string doesn't spawn a subshell).
    read -r _histnum last <<< "$last"
    [[ "$last" == "$__atuin_last_seen" ]] && return 0
    __atuin_last_seen=$last
    [[ -n "$last" ]] || return 0
    printf '%s\t%q\n' "$EXIT" "$last" >&"${__atuin_worker[1]}" 2>/dev/null || :
}

# Install directly in PROMPT_COMMAND (no bash-preexec needed).
PROMPT_COMMAND+=(__atuin_precmd)

# Neutralize stock atuin hooks that depended on bash-preexec arrays.
# __atuin_accept_line (from the search UI) iterates preexec_functions;
# these stubs keep it functional without the DEBUG trap machinery.
__atuin_preexec() { :; }
