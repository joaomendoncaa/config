#!/usr/bin/env bash

# Cache and source zoxide init (avoids forking `zoxide init bash` on
# every startup — saves ~3ms). Regenerate by deleting the cache file.
__zoxide_cache_dir="$HOME/.cache/bash-init"
[[ -d "$__zoxide_cache_dir" ]] || mkdir -p "$__zoxide_cache_dir" 2>/dev/null
__zoxide_cache="$__zoxide_cache_dir/zoxide.bash"

if [[ -s "$__zoxide_cache" ]]; then
    source "$__zoxide_cache"
else
    eval "$(zoxide init bash)"
    zoxide init bash > "$__zoxide_cache" 2>/dev/null || rm -f "$__zoxide_cache"
fi

# Override zoxide's precmd hook to avoid a fork on every prompt. Stock
# __zoxide_hook does `pwd_tmp="$(__zoxide_pwd)"` — command substitution
# forks a subshell every prompt. $PWD is the logical working directory,
# identical to `pwd -L` (what __zoxide_pwd returns), with no fork.
__zoxide_hook() {
    \builtin local -r retval="$?"
    \builtin local pwd_tmp=$PWD
    if [[ ${__zoxide_oldpwd} != "${pwd_tmp}" ]]; then
        __zoxide_oldpwd="${pwd_tmp}"
        \command zoxide add -- "${__zoxide_oldpwd}"
    fi
    \builtin return "${retval}"
}

# Custom cd/cdi commands (not provided by stock zoxide init).
\builtin unalias cd &>/dev/null || \builtin true
function cd() {
    __zoxide_z "$@"
}

\builtin unalias cdi &>/dev/null || \builtin true
function cdi() {
    __zoxide_zi "$@"
}
