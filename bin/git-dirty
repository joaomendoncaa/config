#!/usr/bin/env bash
set -euo pipefail

# Async git dirty check
#  git-dirty check <path>   — spawns a background git status, writes * or '' to file
#  git-dirty read  <path>   — reads the pre-computed file, prints ' *' or nothing
# keyed by path (slashes -> dashes)
# pidfile to debounce git status calls

mode="${1:?usage: git-dirty read|check <path>}"
path="${2:?}"

file="/tmp/git-dirty-${path//\//-}"

case "$mode" in
read)
	[[ -s "$file" ]] && printf ' *'
	;;
check)
	pidfile="$file.pid"
	[[ -f "$pidfile" ]] && kill "$(cat "$pidfile")" 2>/dev/null || true
	(
		cd "$path" 2>/dev/null || exit
		git rev-parse --git-dir &>/dev/null || {
			: >"$file"
			exit
		}
		if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
			printf '*' >"$file"
		else
			: >"$file"
		fi
	) &>/dev/null &
	echo $! >"$pidfile"
	disown 2>/dev/null || true
	;;
*)
	echo "usage: git-dirty read|check <path>" >&2
	exit 1
	;;
esac
