#!/usr/bin/env bash
# Focus a Hyprland window by application class
# Tries: exact match → prefix match → contains match (case-insensitive)
# Usage: hyprland-focus-app <app-name>

set -euo pipefail

app="${1:-}"
[[ -n $app ]] || exit 1

address=$(
  hyprctl clients -j 2>/dev/null |
    jq -r --arg name "${app,,}" \
      '[.[] | select((.class // "") | ascii_downcase | (. == $name or startswith($name) or contains($name)))] | first.address // empty'
)

[[ -n $address ]] || exit 1

hyprctl --batch "dispatch hl.dsp.focus({window = \"address:$address\"})" >/dev/null
