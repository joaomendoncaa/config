#!/usr/bin/env bash

set -euo pipefail

PID_FILE="/tmp/gpu-screen-recorder.pid"

[[ -f ~/.config/user-dirs.dirs ]] && source ~/.config/user-dirs.dirs
OUTPUT_DIR="${OMARCHY_SCREENRECORD_DIR:-${XDG_VIDEOS_DIR:-$HOME/Videos/screen-recordings/}}"

if [[ ! -d "$OUTPUT_DIR" ]]; then
    fyi "Screen recording directory does not exist: $OUTPUT_DIR" "" critical
    exit 1
fi

if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    kill "$(cat "$PID_FILE")"
    rm -f "$PID_FILE"
    last_file=$(ls -t "$OUTPUT_DIR"/*.mp4 2>/dev/null | head -n 1)
    if [[ -n "$last_file" ]]; then
        wl-copy --type text/uri-list "file://$last_file"
    fi
    qs ipc call recording setRecording false
else
    rm -f "$PID_FILE"
    REGION_SELECTION=$(slurp -f "%wx%h+%x+%y")
    if [[ -z "$REGION_SELECTION" ]]; then
        exit 0
    fi
    filename=$(date +%Y-%m-%d_%H-%M-%S).mp4
    qs ipc call recording setRecording true
    gpu-screen-recorder -w "$REGION_SELECTION" -c mp4 -k h264 -ac aac -f 60 -fm vfr -cursor yes -restore-portal-session yes -cr full -fallback-cpu-encoding yes -o "$OUTPUT_DIR/$filename" -q very_high -a device:default_output &
    echo $! > "$PID_FILE"
fi
