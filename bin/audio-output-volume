#!/usr/bin/env bash

action="${1:-}"

if [[ -z $action ]]; then
	echo "Usage: audio-output-volume <raise|lower|mute-toggle|+N|-N>"
	exit 1
fi

case "$action" in
raise) action="+2" ;;
lower) action="-2" ;;
mute-toggle | +* | -*) ;;
*)
	echo "Unknown volume action: $action"
	exit 1
	;;
esac

runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
debounce_file="$runtime_dir/audio-output-volume-mute-toggle.last"
now=$(date +%s%3N)
last=0
if [[ $action == "mute-toggle" ]]; then
	[[ -r $debounce_file ]] && read -r last <"$debounce_file" || true
	if ((now - last < 250)); then
		exit 0
	fi
	printf '%s\n' "$now" >"$debounce_file"
fi

state_dir="$runtime_dir/volume-osd"
state_file="$state_dir/state"

if [[ $action == "mute-toggle" ]]; then
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle >/dev/null
elif [[ $action == +* ]]; then
    step="${action#+}"
    wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 >/dev/null
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ "${step}%+"
elif [[ $action == -* ]]; then
    step="${action#-}"
    wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 >/dev/null
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "${step}%-"
fi

volume_state=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)
percent=$(echo "$volume_state" | awk '{ for (i=1; i<=NF; i++) if ($i ~ /^[0-9.]+$/) print int($i * 100) }')
muted=false
if echo "$volume_state" | grep -q MUTED; then
    muted=true
fi

mkdir -p "$state_dir"
echo "$percent $muted" > "$state_file"
