#!/usr/bin/env bash
set -euo pipefail

LOCKFILE="/tmp/git-checkpoint.lock"

if [[ -f "$LOCKFILE" ]] && kill -0 "$(cat "$LOCKFILE")" 2>/dev/null; then
	notify-send -a git-checkpoint -t 5000 "already running"
	exit 0
fi
echo "$$" >"$LOCKFILE"
trap 'rm -f "$LOCKFILE"' EXIT

notif() { notify-send -a git-checkpoint -t 5000 "$1" 2>/dev/null || true; }

ERRFILE=$(mktemp)
trap 'rm -f "$LOCKFILE" "$ERRFILE"' EXIT

undo_stage() {
	git reset --quiet HEAD -- :/ 2>/dev/null || true
	git diff --cached --name-only --diff-filter=A --no-renames 2>/dev/null |
		xargs -r git rm --cached --quiet 2>/dev/null || true
}

if ! git add -A 2>"$ERRFILE"; then
	notif "failed to stage: $(head -1 "$ERRFILE" | tr -d '\n' | head -c 80)"
	exit 0
fi

DIFF_FILE=$(mktemp)
trap 'rm -f "$LOCKFILE" "$DIFF_FILE" "$ERRFILE"' EXIT

git diff --cached >"$DIFF_FILE" 2>/dev/null
if [[ ! -s "$DIFF_FILE" ]]; then
	undo_stage
	notif "nothing to commit"
	exit 0
fi

LOG_FILE=$(mktemp)
trap 'rm -f "$LOCKFILE" "$DIFF_FILE" "$ERRFILE" "$LOG_FILE"' EXIT
git log --oneline -20 >"$LOG_FILE" 2>/dev/null

RAW=$(timeout 30 \
	opencode run \
	--format json \
	--agent "Git Commit" \
	"Generate a conventional commit message for the attached diff.
Recent commits for style reference are in the attached log file." \
	--file "$LOG_FILE" \
	--file "$DIFF_FILE" \
	--dangerously-skip-permissions \
	--model opencode/deepseek-v4-flash-free \
	2>"$ERRFILE" |
	python3 -c "
import sys, json

last = ''
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        ev = json.loads(line)
    except json.JSONDecodeError:
        continue
    if ev.get('type') != 'text':
        continue
    part = ev.get('part', {})
    if part.get('type') != 'text':
        continue
    text = part.get('text', '')
    if text:
        last = text

lines = last.split('\n')
title = lines[0].strip() if lines else ''
body = '\n'.join(l.strip() for l in lines[1:] if l.strip())
print(title)
print(body)
" 2>/dev/null) || {
	undo_stage
	ERR=$(head -1 "$ERRFILE" | tr -d '\n' | head -c 80)
	notif "failed to generate commit message${ERR:+: $ERR}"
	exit 0
}

TITLE=$(echo "$RAW" | sed -n '1p')
DESC=$(echo "$RAW" | sed -n '2p')

if [[ -z "$TITLE" ]]; then
	undo_stage
	notif "failed to generate commit message"
	exit 0
fi

# Validate conventional commit format
if ! echo "$TITLE" | grep -qiE '^(feat|fix|chore|docs|style|refactor|perf|test|build|ci|revert)(\([^)]*\))?!?: '; then
	undo_stage
	notif "bad commit format: $TITLE"
	exit 0
fi

if [[ -n "$DESC" ]]; then
	if ! git commit -m "$TITLE" -m "$DESC" >/dev/null 2>"$ERRFILE"; then
		undo_stage
		notif "commit failed: $(head -1 "$ERRFILE" | tr -d '\n' | head -c 80)"
		exit 0
	fi
else
	if ! git commit -m "$TITLE" >/dev/null 2>"$ERRFILE"; then
		undo_stage
		notif "commit failed: $(head -1 "$ERRFILE" | tr -d '\n' | head -c 80)"
		exit 0
	fi
fi

if ! git push >/dev/null 2>"$ERRFILE"; then
	notif "push failed: $(head -1 "$ERRFILE" | tr -d '\n' | head -c 80)"
	exit 0
fi

notif "Pushed $TITLE"
