#!/usr/bin/env bash

if pgrep -x wl-screenrec >/dev/null || pgrep -x wf-recorder >/dev/null || pgrep -f gpu-screen-recorder >/dev/null; then
	echo '{"text": "●", "tooltip": "Stop recording" }'
	exit 0
fi

sleep 0.2

if obs-cmd recording status-active >/dev/null 2>&1; then
	echo '{"text": "●", "tooltip": "Stop recording" }'
else
	echo '{"text": ""}'
fi
