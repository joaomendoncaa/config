#!/usr/bin/env bash

set -euo pipefail

if ! obs-cmd info >/dev/null 2>&1; then
	fyi "OBS not running" "" normal
	exit 0
fi

if obs-cmd recording status-active >/dev/null 2>&1; then
	obs-cmd recording stop
	qs ipc call recording setRecording false
else
	obs-cmd recording start
	qs ipc call recording setRecording true
fi
